# Vite fingerprints every file in /assets/ with a content hash, so the contents
# behind a given URL never change — cache them hard. This makes refreshes and
# repeat visits instant (no revalidation round-trip) instead of the current
# max-age=0 default that re-checks every asset on every load.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The HTML entry point must NOT be cached hard — it names the current asset
# hashes, so it has to be revalidated every load or a deploy would be invisible.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
